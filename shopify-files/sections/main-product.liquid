              <!-- JavaScript for Subscription Integration -->
              <script>
                // Purchase type toggle
                document.querySelectorAll('input[name="purchase_type"]').forEach(radio => {
                  radio.addEventListener('change', function() {
                    const purchaseType = this.value;
                    
                    if (purchaseType === 'one-time') {
                      document.getElementById('one-time-section').style.display = 'block';
                      document.getElementById('subscription-section').style.display = 'none';
                      document.getElementById('one-time-button').style.display = 'block';
                      document.getElementById('subscription-button').style.display = 'none';
                    } else {
                      document.getElementById('one-time-section').style.display = 'none';
                      document.getElementById('subscription-section').style.display = 'block';
                      document.getElementById('one-time-button').style.display = 'none';
                      document.getElementById('subscription-button').style.display = 'block';
                    }
                  });
                });

                // Plan selection handler
                document.querySelectorAll('.subscription-option').forEach(option => {
                  option.addEventListener('click', function() {
                    document.querySelectorAll('.subscription-option').forEach(opt => opt.classList.remove('selected'));
                    this.classList.add('selected');
                  });
                });

                // Continue button handler
                document.getElementById('continueBtn').addEventListener('click', function() {
                  const selectedPlan = document.querySelector('.subscription-option.selected');
                  if (!selectedPlan) {
                    alert('Please select a subscription plan');
                    return;
                  }
                  openModal();
                });

                // Modal functions
                function openModal() {
                  document.getElementById('subscriptionModal').classList.add('active');
                }

                function closeModal() {
                  document.getElementById('subscriptionModal').classList.remove('active');
                }

                // Close modal when clicking outside
                document.getElementById('subscriptionModal').addEventListener('click', function(e) {
                  if (e.target === this) {
                    closeModal();
                  }
                });

                // Load subscription configuration
                window.subscriptionConfig = {
                  apiBase: '{{ settings.subscription_api_url | default: "https://shopify-razorpay-backend-production.up.railway.app" }}',
                  razorpay_key_id: '{{ settings.razorpay_key_id | default: "rzp_live_SSfTeiwakEqpU0" }}',
                  customerId: {%- if customer -%}'{{ customer.id }}'{%- else -%}null{%- endif -%},
                  customerEmail: {%- if customer -%}'{{ customer.email }}'{%- else -%}null{%- endif -%},
                  customerPhone: {%- if customer -%}'{{ customer.phone }}'{%- else -%}null{%- endif -%}
                };

                // Store all variant data for dynamic loading
                window.variantData = [
                  {%- for variant in product.variants -%}
                    {
                      id: {{ variant.id }},
                      title: "{{ variant.title | escape }}",
                      price: {{ variant.price }},
                      plans: [
                        {
                          planId: "{{ variant.metafields.custom.razorpay_plan_id_1 }}",
                          frequency: "{{ variant.metafields.custom.frequency_1 }}",
                          description: "{{ variant.metafields.custom.description_1 }}"
                        },
                        {
                          planId: "{{ variant.metafields.custom.razorpay_plan_id_2 }}",
                          frequency: "{{ variant.metafields.custom.frequency_2 }}",
                          description: "{{ variant.metafields.custom.description_2 }}"
                        },
                        {
                          planId: "{{ variant.metafields.custom.razorpay_plan_id_3 }}",
                          frequency: "{{ variant.metafields.custom.frequency_3 }}",
                          description: "{{ variant.metafields.custom.description_3 }}"
                        }
                      ]
                    }{%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                ];

                // Debug: Log variant data to console
                console.log('🔍 All Variant Data:', window.variantData);

                // Function to update subscription plans based on selected tier
                function updateSubscriptionPlans(tierNumber) {
                  const container = document.getElementById('dynamicSubscriptionOptions');
                  
                  // Debug: Log what tier we're looking for
                  console.log(`🎯 Looking for tier: ${tierNumber}`);
                  
                  // Map tier to variant (1 -> variant 1, 2 -> variant 2, 3 -> variant 3)
                  const variantIndex = tierNumber - 1;
                  const variant = window.variantData[variantIndex];
                  
                  console.log(`🔍 Found variant:`, variant);
                  
                  if (!variant) {
                    container.innerHTML = `
                      <p style="text-align: center; color: #6b7280; padding: 20px;">
                        No subscription plans available for this tier
                      </p>
                    `;
                    return;
                  }

                  let html = '';
                  let hasValidPlans = false;
                  const badges = ['FAMILY PACK', '', 'POPULAR'];

                  // Generate HTML for each plan (dropdown rows)
                  variant.plans.forEach((plan, index) => {
                    console.log(`📋 Plan ${index + 1}:`, plan);
                    if (plan.planId && plan.frequency && plan.description) {
                      hasValidPlans = true;
                      const priceInRupees = variant.price / 100;
                      const badge = plan.badge || badges[index] || '';
                      const badgeHtml = badge ? `<span class="plan-badge">${badge}</span>` : '';
                      html += `
                        <div class="subscription-option"
                             data-plan="${plan.frequency}"
                             data-variant-id="${variant.id}"
                             data-plan-id="${plan.planId}"
                             data-price="${variant.price}"
                             data-description="${plan.description}"
                             data-badge="${badge}">
                          <span class="plan-title">${plan.description} ${badgeHtml}</span>
                          <span class="plan-price">₹${priceInRupees}</span>
                        </div>
                      `;
                    } else {
                      console.log(`❌ Plan ${index + 1} missing data:`, { planId: !!plan.planId, frequency: !!plan.frequency, description: !!plan.description });
                    }
                  });

                  if (!hasValidPlans) {
                    container.innerHTML = `<p style="text-align:center;color:#6b7280;padding:16px;">No plans configured for ${variant.title}</p>`;
                    return;
                  }

                  container.innerHTML = html;

                  // Click: select plan, update selected text, close dropdown, show bullets
                  container.querySelectorAll('.subscription-option').forEach(option => {
                    option.addEventListener('click', function() {
                      document.querySelectorAll('.subscription-option').forEach(opt => opt.classList.remove('selected'));
                      this.classList.add('selected');
                      // Update selected display
                      const badge = this.dataset.badge;
                      const badgeHtml = badge ? `<span class="plan-badge">${badge}</span>` : '';
                      const priceInRupees = parseInt(this.dataset.price) / 100;
                      document.getElementById('subFreqSelectedText').innerHTML = `${this.dataset.description} ${badgeHtml} &nbsp;₹${priceInRupees}`;
                      document.getElementById('subFreqDropdown').style.display = 'none';
                      document.querySelector('.sub-freq-arrow').classList.remove('open');
                      // Show bullets and update frequency bullet
                      const bullets = document.getElementById('subBullets');
                      if (bullets) bullets.style.display = 'block';
                      const freqBullet = document.getElementById('subBulletFrequency');
                      if (freqBullet) freqBullet.textContent = `You will receive an order every ${this.dataset.plan}`;
                    });
                  });
                }

                // Function to get current selected tier
                function getCurrentSelectedTier() {
                  const selectedTier = document.querySelector('.cbox__tier.cbox--selected');
                  if (selectedTier) {
                    return parseInt(selectedTier.dataset.tier);
                  }
                  return 2; // Default to tier 2
                }

                // Update subscription plans when box tier changes
                function handleTierChange() {
                  const currentTier = getCurrentSelectedTier();
                  console.log(`Box tier changed to: ${currentTier}`);
                  updateSubscriptionPlans(currentTier);
                }

                // Dropdown toggle
                document.addEventListener('click', function(e) {
                  const selected = document.getElementById('subFreqSelected');
                  const dropdown = document.getElementById('subFreqDropdown');
                  const arrow = document.querySelector('.sub-freq-arrow');
                  if (!selected || !dropdown) return;
                  if (selected.contains(e.target)) {
                    const isOpen = dropdown.style.display !== 'none';
                    dropdown.style.display = isOpen ? 'none' : 'block';
                    if (arrow) arrow.classList.toggle('open', !isOpen);
                  } else if (!dropdown.contains(e.target)) {
                    dropdown.style.display = 'none';
                    if (arrow) arrow.classList.remove('open');
                  }
                });

                // Add event listeners to box tier selection
                document.addEventListener('DOMContentLoaded', function() {
                  // Initial load
                  setTimeout(() => {
                    handleTierChange();
                  }, 100);

                  // Listen for tier changes — reset dropdown selection when box changes
                  const tierCards = document.querySelectorAll('.cbox__tier');
                  tierCards.forEach(card => {
                    card.addEventListener('click', function() {
                      setTimeout(() => {
                        handleTierChange();
                        // Reset dropdown UI
                        const freqText = document.getElementById('subFreqSelectedText');
                        if (freqText) freqText.textContent = 'Select a plan';
                        const dropdown = document.getElementById('subFreqDropdown');
                        if (dropdown) dropdown.style.display = 'none';
                        const bullets = document.getElementById('subBullets');
                        if (bullets) bullets.style.display = 'none';
                      }, 50);
                    });
                  });
                });

                // Load subscription mandate script (ensure Razorpay is loaded first)
                setTimeout(() => {
                  if (typeof window.subscriptionProductUpdated === 'undefined') {
                    const script = document.createElement('script');
                    script.src = '{{ "subscription-product-updated.js" | asset_url }}';
                    script.onload = function() {
                      console.log('Subscription mandate script loaded');
                      // Manually initialize since DOMContentLoaded might have already fired
                      if (typeof SubscriptionProductUpdated !== 'undefined' && typeof window.subscriptionProductUpdated === 'undefined') {
                        window.subscriptionProductUpdated = new SubscriptionProductUpdated();
                        console.log('Subscription product manually initialized');
                      }
                    };
                    script.onerror = function() {
                      console.error('Failed to load subscription mandate script');
                    };
                    document.head.appendChild(script);
                  } else {
                    console.log('Subscription product already initialized');
                  }
                }, 500); // Small delay to ensure Razorpay is fully loaded
              </script>
            {%- endif -%}

