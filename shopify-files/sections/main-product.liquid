{%- when 'price_for_box' -%}
  {% comment %} Price For Box - Updates when tier is selected in customize_box {% endcomment %}
  <div
    id="price-for-box-{{ section.id }}"
    class="price-for-box mb-10{% if enable_skeleton_loading %} skeleton-loading{% endif %}"
    {{ block.shopify_attributes }}
    style="display: none;"
  >
    <div class="price-for-box__inner">
      {% if block_st.label != blank %}
        <span class="price-for-box__label" style="font-size: {{ block_st.label_font_size | default: 14 }}px; color: {{ block_st.label_color | default: '#666666' }}; display: block; margin-bottom: 4px;">
          {{ block_st.label }}
        </span>
      {% endif %}
      <div class="price-for-box__prices flex align-center gap-10 flex-wrap">
        <span
          id="price-for-box-current-{{ section.id }}"
          class="price-for-box__current"
          style="font-size: {{ block_st.price_font_size | default: 28 }}px; font-weight: {{ block_st.font_weight | default: '700' }}; color: {{ block_st.price_color | default: '#111111' }};"
        ></span>
        <span
          id="price-for-box-compare-{{ section.id }}"
          class="price-for-box__compare"
          style="font-size: {{ block_st.compare_font_size | default: 18 }}px; color: {{ block_st.compare_color | default: '#999999' }}; text-decoration: line-through; display: none;"
        ></span>
        <span
          id="price-for-box-savings-{{ section.id }}"
          class="price-for-box__savings"
          style="font-size: {{ block_st.savings_font_size | default: 13 }}px; font-weight: 600; color: {{ block_st.savings_color | default: '#2e7d32' }}; display: none;"
        ></span>
      </div>
    </div>
  </div>

  <script>
  (function () {
    var sid = '{{ section.id }}';
    var wrapEl     = document.getElementById('price-for-box-' + sid);
    var currentEl  = document.getElementById('price-for-box-current-' + sid);
    var compareEl  = document.getElementById('price-for-box-compare-' + sid);
    var savingsEl  = document.getElementById('price-for-box-savings-' + sid);

    if (!wrapEl || !currentEl) return;

    function formatMoney(cents) {
      var currency = (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) ? window.Shopify.currency.active : 'INR';
      try {
        return new Intl.NumberFormat('en-IN', { style: 'currency', currency: currency, maximumFractionDigits: 0 }).format(cents / 100);
      } catch(e) {
        return currency + ' ' + (cents / 100).toFixed(0);
      }
    }

    function updatePriceForBox(variantId) {
      if (!variantId) return;
      currentEl.textContent = '...';
      wrapEl.style.display = 'block';

      fetch('/variants/' + variantId + '.js')
        .then(function(r) { return r.json(); })
        .then(function(v) {
          if (!v || v.price == null) return;

          currentEl.textContent = formatMoney(v.price);

          if (v.compare_at_price && v.compare_at_price > v.price) {
            compareEl.textContent = formatMoney(v.compare_at_price);
            compareEl.style.display = 'inline';

            var saved = v.compare_at_price - v.price;
            var pct   = Math.round(saved / v.compare_at_price * 100);
            savingsEl.textContent = 'Save ' + formatMoney(saved) + ' (' + pct + '% off)';
            savingsEl.style.display = 'inline';
          } else {
            compareEl.style.display = 'none';
            savingsEl.style.display = 'none';
          }
        })
        .catch(function() { currentEl.textContent = ''; });
    }

    /* Listen for tier selection inside the customize_box block */
    document.addEventListener('click', function(e) {
      var tier = e.target.closest('.cbox__tier[data-section="' + sid + '"]');
      if (!tier) return;
      var vid = tier.dataset.variant;
      if (vid) updatePriceForBox(vid);
    });

    /* On page load: pick the default selected tier (Tier 2 = cbox--selected) */
    function init() {
      var box = document.getElementById('customize-box-' + sid);
      if (!box) return;
      var defaultTier = box.querySelector('.cbox__tier.cbox--selected');
      if (defaultTier && defaultTier.dataset.variant) {
        updatePriceForBox(defaultTier.dataset.variant);
      }
    }

    /* Wait for customize_box script to finish its own init */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      setTimeout(init, 100);
    }
  })();
  </script>


{%- when 'customize_box' -%}
  {% comment %} Customize Your Box {% endcomment %}
  {%- liquid
    assign box_total     = block_st.box_total     | default: 12
    assign pad1_label    = block_st.pad1_label    | default: 'Heavy (XXL)'
    assign pad2_label    = block_st.pad2_label    | default: 'Medium (XL)'
    assign pad3_label    = block_st.pad3_label    | default: 'Light (L)'
    assign pad1_default  = block_st.pad1_default  | default: 4
    assign pad2_default  = block_st.pad2_default  | default: 4
    assign pad3_default  = block_st.pad3_default  | default: 4
    assign section_heading         = block_st.section_heading         | default: 'Customize your box'
    assign info_tooltip            = block_st.info_tooltip            | default: 'Choose how many pads of each type you want.'
    assign what_should_i_get_label = block_st.what_should_i_get_label | default: 'What should I get?'
    assign what_should_i_get_url   = block_st.what_should_i_get_url   | default: '#'
    assign box_contains_label      = block_st.box_contains_label      | default: 'Your box contains'
    assign pads_label              = block_st.pads_label              | default: 'pads'
    assign accent                  = block_st.accent_color            | default: '#c0392b'
    assign footer_bg               = block_st.footer_bg_color         | default: '#f0ebe3'
    assign footer_ok               = block_st.footer_ok_color         | default: '#d4edda'
    assign tier_bg                 = block_st.tier_bg                 | default: '#ffffff'
    assign tier_sel_bg             = block_st.tier_selected_bg        | default: '#fdf0f0'
    assign text_col                = block_st.text_color              | default: '#111111'
    assign div_col                 = block_st.divider_color           | default: '#eeeeee'
    assign qty_border              = block_st.qty_border_color        | default: '#cccccc'
    assign qty_bg                  = block_st.qty_btn_bg              | default: '#ffffff'
  -%}

  {% comment %} --- UPDATED CONSOLIDATED INPUTS --- {% endcomment %}
  <input type="hidden" id="cbprop-items-{{ section.id }}" name="properties[Items]" value="" form="{{ product_form_id }}">
  <input type="hidden" id="cbprop-boxes-{{ section.id }}" name="properties[Boxes]" value="" form="{{ product_form_id }}">

  <div
    class="customize-box mb-25{% if enable_skeleton_loading %} skeleton-loading{% endif %}"
    {{ block.shopify_attributes }}
    id="customize-box-{{ section.id }}"
    data-box-total="{{ box_total }}"
    data-pad1="{{ pad1_label }}"
    data-pad2="{{ pad2_label }}"
    data-pad3="{{ pad3_label }}"
    data-pads-label="{{ pads_label }}"
    data-form-id="{{ product_form_id }}"
    data-footer-bg="{{ footer_bg }}"
    data-footer-ok="{{ footer_ok }}"
    data-accent="{{ accent }}"
  >

    {% comment %} ── CUSTOMIZE YOUR BOX ── {% endcomment %}
    <div class="cbox__wrapper" style="border:1px solid #e5e5e5;border-radius:10px;overflow:hidden;background:{{ block_st.box_bg_color | default: '#ffffff' }};">

      <div class="cbox__header" style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px 14px;flex-wrap:wrap;gap:8px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-weight:700;font-size:{{ block_st.heading_font_size | default: 18 }}px;color:{{ text_col }};">{{ section_heading }}</span>
          <span class="cbox__tooltip-wrap" style="position:relative;display:inline-flex;">
            <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;border:2px solid {{ accent }};color:{{ accent }};font-size:11px;font-weight:700;cursor:pointer;line-height:1;flex-shrink:0;">i</span>
            <span class="cbox__tip" style="display:none;position:absolute;top:26px;left:50%;transform:translateX(-50%);background:#333;color:#fff;font-size:12px;padding:6px 10px;border-radius:5px;white-space:nowrap;z-index:20;pointer-events:none;">{{ info_tooltip }}</span>
          </span>
        </div>
        {% if what_should_i_get_label != blank %}
          <a href="{{ what_should_i_get_url }}" style="font-size:13px;color:{{ block_st.link_color | default: '#333' }};text-decoration:none;white-space:nowrap;">{{ what_should_i_get_label }}</a>
        {% endif %}
      </div>

      {% comment %} Pad rows {% endcomment %}
      {% assign _pad_labels   = pad1_label   | append: '||' | append: pad2_label   | append: '||' | append: pad3_label   | split: '||' %}
      {% assign _pad_defaults = pad1_default | append: '||' | append: pad2_default | append: '||' | append: pad3_default | split: '||' %}

      {% for i in (1..3) %}
        {% assign _lbl  = _pad_labels[forloop.index0] %}
        {% assign _def  = _pad_defaults[forloop.index0] | plus: 0 %}
        {% assign _ikey = 'pad' | append: forloop.index | append: '_icon' %}
        {% assign _ico  = block_st[_ikey] %}

        <div class="cbox__row" style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-top:1px solid {{ div_col }};">
          <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0;">
            {% if _ico != blank %}
              <img src="{{ _ico | img_url: 'x48' }}" width="28" height="40" alt="{{ _lbl }}" style="object-fit:contain;flex-shrink:0;">
            {% else %}
              <svg width="22" height="36" viewBox="0 0 22 36" fill="none" style="flex-shrink:0;">
                {% if forloop.index == 1 %}<rect x="1" y="1" width="20" height="34" rx="10" fill="{{ accent }}"/>
                {% elsif forloop.index == 2 %}<rect x="1" y="1" width="20" height="34" rx="10" fill="{{ accent }}" opacity="0.6"/>
                {% else %}<rect x="1" y="1" width="20" height="34" rx="10" fill="#e8c9a0"/>{% endif %}
              </svg>
            {% endif %}
            <span style="font-size:{{ block_st.row_font_size | default: 15 }}px;font-weight:500;color:{{ text_col }};overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ _lbl }}</span>
          </div>
          <div style="display:flex;align-items:center;flex-shrink:0;margin-left:12px;">
            <button type="button" class="cbox__minus"
              data-idx="{{ forloop.index }}" data-section="{{ section.id }}"
              style="width:36px;height:36px;border:1px solid {{ qty_border }};border-right:none;border-radius:4px 0 0 4px;background:{{ qty_bg }};font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:{{ text_col }};padding:0;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">−</button>
            <span id="cbox-qty-{{ section.id }}-{{ forloop.index }}"
              style="width:40px;height:36px;display:flex;align-items:center;justify-content:center;border-top:1px solid {{ qty_border }};border-bottom:1px solid {{ qty_border }};font-size:15px;font-weight:600;color:{{ text_col }};background:{{ qty_bg }};">{{ _def }}</span>
            <button type="button" class="cbox__plus"
              data-idx="{{ forloop.index }}" data-section="{{ section.id }}"
              style="width:36px;height:36px;border:1px solid {{ qty_border }};border-left:none;border-radius:0 4px 4px 0;background:{{ qty_bg }};font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:{{ text_col }};padding:0;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">+</button>
          </div>
        </div>
      {% endfor %}

      {% comment %} Footer {% endcomment %}
      <div id="cbox-footer-{{ section.id }}" style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;background:{{ footer_bg }};border-top:1px solid {{ div_col }};transition:background 0.3s;">
        <span style="font-size:14px;font-weight:600;color:{{ text_col }};">{{ box_contains_label }}</span>
        <span id="cbox-total-{{ section.id }}" style="font-size:14px;font-weight:700;color:{{ text_col }};">{{ pad1_default | plus: pad2_default | plus: pad3_default }} / {{ box_total }} {{ pads_label }}</span>
      </div>

      {% comment %} Validation error {% endcomment %}
      <div id="cbox-error-{{ section.id }}" style="display:none;padding:10px 20px;background:#fff3f3;color:{{ accent }};font-size:13px;font-weight:600;border-top:2px solid {{ accent }};">
        ⚠️ Please select exactly {{ box_total }} pads before adding to cart.
      </div>
    </div>

    {% comment %} ── CHOOSE BOXES ── {% endcomment %}
    {% if block_st.show_box_selector %}
      <div style="margin-top:22px;">
        {% if block_st.choose_boxes_heading != blank %}
          <h3 style="margin:0 0 14px;font-size:{{ block_st.heading_font_size | default: 18 }}px;font-weight:700;color:{{ text_col }};">{{ block_st.choose_boxes_heading }}</h3>
        {% endif %}

        <div class="cbox__tiers" style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">

          {% comment %} Tier 1 {% endcomment %}
          {% if block_st.tier1_label != blank %}
            <div class="cbox__tier"
              data-tier="1" data-section="{{ section.id }}"
              data-boxes="{{ block_st.tier1_boxes | default: 1 }}"
              data-variant="{{ block_st.tier1_variant_id }}"
              style="border:2px solid #ddd;border-radius:8px;overflow:hidden;cursor:pointer;background:{{ tier_bg }};display:flex;flex-direction:column;">
              <div style="flex:1;padding:12px 8px 10px;text-align:center;">
                {% if block_st.tier1_image != blank %}<img src="{{ block_st.tier1_image | img_url: 'x80' }}" width="52" height="52" alt="{{ block_st.tier1_label }}" style="object-fit:contain;margin:0 auto 6px;display:block;">{% endif %}
                <div style="font-size:14px;font-weight:600;color:{{ text_col }};">{{ block_st.tier1_label }}</div>
                <div style="font-size:11px;color:#777;margin-bottom:4px;">{{ block_st.tier1_sublabel }}</div>
                <div id="cbox-tier-price-{{ section.id }}-1" style="font-size:16px;font-weight:700;color:{{ text_col }};min-height:22px;"></div>
              </div>
              <div class="cbox__tier-foot" style="padding:7px 4px;background:#bbb;color:#fff;font-size:12px;font-weight:600;text-align:center;">{{ block_st.tier1_per_pad }}</div>
            </div>
          {% endif %}

          {% comment %} Tier 2 {% endcomment %}
          {% if block_st.tier2_label != blank %}
            <div class="cbox__tier cbox--selected"
              data-tier="2" data-section="{{ section.id }}"
              data-boxes="{{ block_st.tier2_boxes | default: 2 }}"
              data-variant="{{ block_st.tier2_variant_id }}"
              style="border:2px solid #ddd;border-radius:8px;overflow:hidden;cursor:pointer;background:{{ tier_bg }};display:flex;flex-direction:column;">
              <div style="flex:1;padding:12px 8px 10px;text-align:center;">
                {% if block_st.tier2_image != blank %}<img src="{{ block_st.tier2_image | img_url: 'x80' }}" width="52" height="52" alt="{{ block_st.tier2_label }}" style="object-fit:contain;margin:0 auto 6px;display:block;">{% endif %}
                <div style="font-size:14px;font-weight:600;color:{{ text_col }};">{{ block_st.tier2_label }}</div>
                <div style="font-size:11px;color:#777;margin-bottom:4px;">{{ block_st.tier2_sublabel }}</div>
                <div id="cbox-tier-price-{{ section.id }}-2" style="font-size:16px;font-weight:700;color:{{ text_col }};min-height:22px;"></div>
                {% if block_st.tier2_discount != blank %}
                  <div style="display:flex;align-items:center;justify-content:center;gap:4px;margin-top:3px;flex-wrap:wrap;">
                    <span style="background:{{ accent }};color:#fff;border-radius:50%;width:18px;height:18px;font-size:9px;display:inline-flex;align-items:center;justify-content:center;">%</span>
                    <span style="font-size:12px;font-weight:600;color:{{ accent }};">{{ block_st.tier2_discount }}</span>
                    <span id="cbox-tier-compare-{{ section.id }}-2" style="font-size:11px;color:#999;text-decoration:line-through;"></span>
                  </div>
                {% endif %}
              </div>
              <div class="cbox__tier-foot" style="padding:7px 4px;background:#bbb;color:#fff;font-size:12px;font-weight:600;text-align:center;">{{ block_st.tier2_per_pad }}</div>
            </div>
          {% endif %}

          {% comment %} Tier 3 {% endcomment %}
          {% if block_st.tier3_label != blank %}
            <div class="cbox__tier"
              data-tier="3" data-section="{{ section.id }}"
              data-boxes="{{ block_st.tier3_boxes | default: 3 }}"
              data-variant="{{ block_st.tier3_variant_id }}"
              style="position:relative;border:2px solid #ddd;border-radius:8px;overflow:hidden;cursor:pointer;background:{{ tier_bg }};display:flex;flex-direction:column;">
              {% if block_st.tier3_best_deal_label != blank %}
                <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);background:{{ block_st.best_deal_bg | default: '#e67e22' }};color:#fff;font-size:10px;font-weight:700;padding:2px 10px;border-radius:0 0 5px 5px;letter-spacing:0.5px;white-space:nowrap;z-index:1;">{{ block_st.tier3_best_deal_label }}</div>
              {% endif %}
              <div style="flex:1;padding:20px 8px 10px;text-align:center;">
                {% if block_st.tier3_image != blank %}<img src="{{ block_st.tier3_image | img_url: 'x80' }}" width="52" height="52" alt="{{ block_st.tier3_label }}" style="object-fit:contain;margin:0 auto 6px;display:block;">{% endif %}
                <div style="font-size:14px;font-weight:600;color:{{ text_col }};">{{ block_st.tier3_label }}</div>
                <div style="font-size:11px;color:#777;margin-bottom:4px;">{{ block_st.tier3_sublabel }}</div>
                <div id="cbox-tier-price-{{ section.id }}-3" style="font-size:16px;font-weight:700;color:{{ text_col }};min-height:22px;"></div>
                {% if block_st.tier3_discount != blank %}
                  <div style="display:flex;align-items:center;justify-content:center;gap:4px;margin-top:3px;flex-wrap:wrap;">
                    <span style="background:{{ accent }};color:#fff;border-radius:50%;width:18px;height:18px;font-size:9px;display:inline-flex;align-items:center;justify-content:center;">%</span>
                    <span style="font-size:12px;font-weight:600;color:{{ accent }};">{{ block_st.tier3_discount }}</span>
                    <span id="cbox-tier-compare-{{ section.id }}-3" style="font-size:11px;color:#999;text-decoration:line-through;"></span>
                  </div>
                {% endif %}
              </div>
              <div class="cbox__tier-foot" style="padding:7px 4px;background:#bbb;color:#fff;font-size:12px;font-weight:600;text-align:center;">{{ block_st.tier3_per_pad }}</div>
            </div>
          {% endif %}

        </div>
      </div>
    {% endif %}

  </div><style>
    #customize-box-{{ section.id }} .cbox__tier { transition:border-color .15s, background .15s; }
    #customize-box-{{ section.id }} .cbox__tier.cbox--selected { border-color:{{ accent }} !important; background:{{ tier_sel_bg }} !important; }
    #customize-box-{{ section.id }} .cbox__tier.cbox--selected .cbox__tier-foot { background:{{ accent }} !important; }
    #customize-box-{{ section.id }} .cbox__tooltip-wrap:hover .cbox__tip { display:block !important; }
    #customize-box-{{ section.id }} .cbox__minus:active,
    #customize-box-{{ section.id }} .cbox__plus:active  { background:{{ block_st.qty_btn_hover_bg | default: '#f0f0f0' }} !important; }

    @media (max-width:480px) {
      #customize-box-{{ section.id }} .cbox__tiers      { gap:6px; }
      #customize-box-{{ section.id }} .cbox__row        { padding:12px 14px !important; }
      #customize-box-{{ section.id }} .cbox__header     { padding:14px 14px 12px !important; }
      #customize-box-{{ section.id }} #cbox-footer-{{ section.id }} { padding:12px 14px !important; }
      #customize-box-{{ section.id }} .cbox__tier > div:first-of-type { padding-left:4px !important; padding-right:4px !important; }
      #customize-box-{{ section.id }} .cbox__tier img   { width:36px !important; height:36px !important; }
      #customize-box-{{ section.id }} .cbox__tier div[style*="font-size:14px"] { font-size:12px !important; }
      #customize-box-{{ section.id }} .cbox__tier div[style*="font-size:16px"] { font-size:14px !important; }
      #customize-box-{{ section.id }} .cbox__tier-foot  { font-size:10px !important; padding:5px 2px !important; }
    }
  </style>

  <script>
(function () {
  const wrap = document.getElementById('customize-box-{{ section.id }}');
  if (!wrap) return;

  const sid       = '{{ section.id }}';
  const boxTotal  = parseInt(wrap.dataset.boxTotal) || 12;
  const padsLabel = wrap.dataset.padsLabel || 'pads';
  const footerBg  = wrap.dataset.footerBg;
  const footerOk  = wrap.dataset.footerOk;
  const productFormId = "{{ product_form_id }}";

  // 1. Initial Quantities
  let qty = { 
    1: parseInt("{{ pad1_default }}") || 0, 
    2: parseInt("{{ pad2_default }}") || 0, 
    3: parseInt("{{ pad3_default }}") || 0 
  };
  
  // 2. Identify the Default Tier 2 Variant ID
  const tier2Card = wrap.querySelector('.cbox__tier[data-tier="2"]');
  const defaultVariantId = tier2Card ? tier2Card.dataset.variant : null;

  const totalEl  = document.getElementById('cbox-total-'  + sid);
  const footerEl = document.getElementById('cbox-footer-' + sid);
  const errorEl  = document.getElementById('cbox-error-' + sid);
  const itemsInput = document.getElementById('cbprop-items-' + sid);
  const tierCards = wrap.querySelectorAll('.cbox__tier');

  function formatMoney(cents) {
    const currency = (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) ? window.Shopify.currency.active : 'INR';
    try {
      return new Intl.NumberFormat('en-IN', { style: 'currency', currency: currency, maximumFractionDigits: 0 }).format(cents / 100);
    } catch(e) { return (cents / 100).toFixed(0); }
  }

  function forceSwitchVariant(variantId) {
    if (!variantId) return;
    
    const idInputs = document.querySelectorAll(`form[id="${productFormId}"] input[name="id"], .feature-product-form input[name="id"], form[action="/cart/add"] input[name="id"]`);
    
    idInputs.forEach(input => {
      input.value = variantId;
      input.dispatchEvent(new Event('change', { bubbles: true }));
    });

    console.log("Forcing Variant ID to:", variantId);
  }

  // NEW: Function to enable/disable add to cart button
  function updateAddToCartButton() {
    const currentTotal = qty[1] + qty[2] + qty[3];
    const submitButton = document.querySelector(`form[id="${productFormId}"] button[type="submit"]`);
    const addToCartForm = document.querySelector(`form[id="${productFormId}"]`);
    
    if (submitButton) {
      if (currentTotal === boxTotal) {
        // Enable button and remove error message
        submitButton.disabled = false;
        submitButton.style.opacity = '1';
        submitButton.style.cursor = 'pointer';
        if (errorEl) errorEl.style.display = 'none';
      } else {
        // Disable button and show error message
        submitButton.disabled = true;
        submitButton.style.opacity = '0.5';
        submitButton.style.cursor = 'not-allowed';
        if (errorEl) errorEl.style.display = 'block';
      }
    }
  }

  function refresh() {
    const currentTotal = qty[1] + qty[2] + qty[3];
    
    [1, 2, 3].forEach(i => {
      const el = document.getElementById('cbox-qty-' + sid + '-' + i);
      if (el) el.textContent = qty[i];
    });

    if (totalEl) totalEl.textContent = `${currentTotal} / ${boxTotal} ${padsLabel}`;
    if (footerEl) footerEl.style.background = (currentTotal === boxTotal) ? footerOk : footerBg;

    if (itemsInput) {
      let summary = [];
      const padLabels = [wrap.dataset.pad1, wrap.dataset.pad2, wrap.dataset.pad3];
      [1, 2, 3].forEach(i => { if (qty[i] > 0) summary.push(`${padLabels[i-1]}: ${qty[i]}`); });
      itemsInput.value = summary.join(', ');
    }

    // NEW: Update box selection in cart properties
    const boxesInput = document.getElementById('cbprop-boxes-' + sid);
    if (boxesInput) {
      const selectedTier = wrap.querySelector('.cbox__tier.cbox--selected');
      if (selectedTier) {
        const tierNumber = parseInt(selectedTier.dataset.tier);
        const tierLabels = ['One Box', 'Two Boxes', 'Three Boxes'];
        boxesInput.value = tierLabels[tierNumber - 1] || `Tier ${tierNumber}`;
        console.log(`📦 Box selection updated: ${boxesInput.value}`);
      }
    }

    // NEW: Update button state
    updateAddToCartButton();
  }

  // Click Handlers
  tierCards.forEach(card => {
    card.addEventListener('click', function() {
      tierCards.forEach(c => c.classList.remove('cbox--selected'));
      this.classList.add('cbox--selected');
      forceSwitchVariant(this.dataset.variant);
      refresh();
    });
  });

  wrap.addEventListener('click', function(e) {
    const btn = e.target.closest('.cbox__minus, .cbox__plus');
    if (!btn) return;
    const idx = parseInt(btn.dataset.idx);
    const currentTotal = qty[1] + qty[2] + qty[3];
    if (btn.classList.contains('cbox__plus')) {
      if (currentTotal < boxTotal) qty[idx]++;
    } else {
      if (qty[idx] > 0) qty[idx]--;
    }
    refresh();
  });

  // --- INITIALIZATION ---
  function init() {
    if (tier2Card) {
      tierCards.forEach(c => c.classList.remove('cbox--selected'));
      tier2Card.classList.add('cbox--selected');
    }

    forceSwitchVariant(defaultVariantId);

    setTimeout(() => {
      forceSwitchVariant(defaultVariantId);
    }, 500);

    refresh();

    tierCards.forEach(card => {
      const vid = card.dataset.variant;
      const tier = card.dataset.tier;
      if (!vid) return;
      fetch('/variants/' + vid + '.js').then(r => r.json()).then(v => {
        const pEl = document.getElementById('cbox-tier-price-' + sid + '-' + tier);
        if (pEl) pEl.textContent = formatMoney(v.price);
      });
    });
  }

  init();
})();
  </script>

          {%- when 'whatsapp_message' -%}
            {% comment %} WhatsApp Message Block - Valentine's Day Edition {% endcomment %}
            {%- if product.metafields.custom.whatsapp and product.metafields.custom.whatsapp != blank -%}
              <div
                class="whatsapp-message-container mb-25{% if enable_skeleton_loading %} skeleton-loading{% endif %}"
                {{ block.shopify_attributes }}
              >
                <button
                  type="button"
                  class="whatsapp-btn-valentine flex align-center justify-center gap-12 w-full pointer px-20 rounded-8 transition-all duration-300 no-underline font-weight-600 fs-16 shadow-md hover:shadow-lg"
                  data-product-id="{{ product.id }}"
                  data-product-title="{{ product.title | escape }}"
                  data-product-price="{{ product.selected_or_first_available_variant.price | money }}"
                  data-product-url="{{ request.origin }}{{ product.url }}"
                  data-custom-message="{{ block_st.message | escape }}"
                  style="
                    padding-top: {{ block_st.button_padding_top | default: 16 }}px;
                    padding-bottom: {{ block_st.button_padding_bottom | default: 16 }}px;
                    background-color: {{ block_st.button_bg_color | default: '#ff69b4' }};
                    color: {{ block_st.button_text_color | default: '#FFFFFF' }};
                    border: none;
                    cursor: pointer;
                  "
                  onmouseover="this.style.backgroundColor='{{ block_st.button_hover_color | default: '#1DA851' }}'"
                  onmouseout="this.style.backgroundColor='{{ block_st.button_bg_color | default: '#25D366' }}'"
                  onclick="handleWhatsAppRedirect(this)"
                >
                  <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
