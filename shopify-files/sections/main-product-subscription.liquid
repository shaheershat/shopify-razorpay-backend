<div class="container mx-auto px-4 py-8">
  <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
    
    <div class="product-wrapper">
      
      <!-- LEFT: IMAGES -->
      <div class="product-images">
        {%- if product.featured_image -%}
          <img id="mainProductImage"
               src="{{ product.featured_image | img_url: 'large' }}"
               class="w-full rounded-lg">
        {%- endif -%}

        <!-- Thumbnails -->
        <div class="thumbnail-container">
          {%- for image in product.images -%}
            <img src="{{ image | img_url: 'small' }}"
                 onclick="document.getElementById('mainProductImage').src='{{ image | img_url: 'large' }}'">
          {%- endfor -%}
        </div>
      </div>

      <!-- RIGHT: DETAILS -->
      <div class="product-details">

        <!-- TITLE -->
        <div class="product-title">
          <h1 class="text-3xl font-bold mb-4">{{ product.title }}</h1>
        </div>

        <!-- SUBSCRIPTION FULL BLOCK -->
        <div class="subscription-block">

          {%- if product.tags contains 'subscription' -%}
          <div class="mb-6">
            <h3 class="section-heading">Choose Subscription Plan</h3>
            <div class="space-y-3" id="subscriptionOptions">
              {%- for variant in product.variants -%}
                {%- assign frequency = variant.metafields.custom.frequency -%}
                {%- assign plan_id = variant.metafields.custom.razorpay_plan_id -%}
                {%- if frequency and plan_id -%}
                  <div class="subscription-option" 
                      data-plan="{{ frequency }}"
                      data-variant-id="{{ variant.id }}"
                      data-plan-id="{{ plan_id }}"
                      data-price="{{ variant.price }}">
                    <div class="flex justify-between items-center">
                      <div>
                        <h4 class="plan-title">{{ variant.title }}</h4>
                        <p class="plan-description">{{ variant.metafields.custom.description }}</p>
                      </div>
                      <div class="text-right">
                        <p class="plan-price">{{ variant.price | money }}/month</p>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
          {%- endif -%}

          <!-- CONTINUE BUTTON -->
          <div class="flex gap-3 mb-6">
            <button id="continueBtn" class="flex-1 py-3 rounded-lg font-semibold btn-continue">
              Continue
            </button>
          </div>

        </div>

        <!-- DESCRIPTION -->
        <div class="description-block">
          <p class="description-text">{{ product.description }}</p>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- MODAL -->
<div class="modal-overlay" id="subscriptionModal">
  <div class="modal-content">
    <button class="modal-close" onclick="closeModal()">&times;</button>
    <h2 class="modal-header">Complete Your Subscription</h2>
    
    <!-- CUSTOMER INFO -->
    <div class="mb-6">
      <h3 class="section-heading">Customer Information</h3>
      <div class="space-y-3">
        {%- if customer -%}
          <input type="email" id="customerEmail" value="{{ customer.email }}" class="w-full border rounded-lg px-4 py-2 input-field" readonly>
          <input type="tel" id="customerPhone" value="{{ customer.phone }}" class="w-full border rounded-lg px-4 py-2 input-field">
        {%- else -%}
          <input type="email" id="customerEmail" placeholder="Email Address" class="w-full border rounded-lg px-4 py-2 input-field">
          <input type="tel" id="customerPhone" placeholder="Phone Number" class="w-full border rounded-lg px-4 py-2 input-field">
        {%- endif -%}
      </div>
    </div>

    <!-- SHIPPING ADDRESS -->
    <div class="mb-6">
      <h3 class="section-heading">Shipping Address</h3>
      <div class="space-y-3">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <input type="text" id="firstName" placeholder="First Name" class="w-full border rounded-lg px-4 py-2 input-field">
          <input type="text" id="lastName" placeholder="Last Name" class="w-full border rounded-lg px-4 py-2 input-field">
        </div>
        <input type="text" id="addressLine1" placeholder="Address Line 1" class="w-full border rounded-lg px-4 py-2 input-field">
        <input type="text" id="addressLine2" placeholder="Address Line 2 (Optional)" class="w-full border rounded-lg px-4 py-2 input-field">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <input type="text" id="city" placeholder="City" class="w-full border rounded-lg px-4 py-2 input-field">
          <input type="text" id="state" placeholder="State" class="w-full border rounded-lg px-4 py-2 input-field">
          <input type="text" id="postalCode" placeholder="PIN Code" class="w-full border rounded-lg px-4 py-2 input-field">
        </div>
      </div>
    </div>

    <!-- BUTTONS -->
    <div class="flex gap-3">
      <button id="subscribeNowBtn" class="flex-1 py-3 rounded-lg font-semibold btn-subscribe">
        Subscribe with Auto-pay
      </button>
    </div>
  </div>
</div>

<!-- Hidden configuration -->
<script>
  window.subscriptionConfig = {
    apiBase: '{{ settings.subscription_api_url | default: "https://shopify-razorpay-backend-production.up.railway.app" }}',
    razorpay_key_id: '{{ settings.razorpay_key_id | default: "rzp_live_SSfTeiwakEqpU0" }}',
    customerId: {%- if customer -%}'{{ customer.id }}'{%- else -%}null{%- endif -%},
    customerEmail: {%- if customer -%}'{{ customer.email }}'{%- else -%}null{%- endif -%},
    customerPhone: {%- if customer -%}'{{ customer.phone }}'{%- else -%}null{%- endif -%}
  };

  // Plan selection handler
  document.querySelectorAll('.subscription-option').forEach(option => {
    option.addEventListener('click', function() {
      document.querySelectorAll('.subscription-option').forEach(opt => opt.classList.remove('selected'));
      this.classList.add('selected');
    });
  });

  // Continue button handler
  document.getElementById('continueBtn').addEventListener('click', function() {
    const selectedPlan = document.querySelector('.subscription-option.selected');
    if (!selectedPlan) {
      alert('Please select a subscription plan');
      return;
    }
    openModal();
  });

  // Modal functions
  function openModal() {
    document.getElementById('subscriptionModal').classList.add('active');
  }

  function closeModal() {
    document.getElementById('subscriptionModal').classList.remove('active');
  }

  // Close modal when clicking outside
  document.getElementById('subscriptionModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });
</script>

