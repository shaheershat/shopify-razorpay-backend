{{ 'subscription-product.css' | asset_url | stylesheet_tag }}

<!-- Load Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/razorpay.js"></script>

<!-- Initialize with correct key -->
<script>
  // Override any existing Razorpay configuration
  if (typeof window.Razorpay !== 'undefined') {
    console.log('🔥 Razorpay already loaded, using new key');
  }
</script>

{{ 'subscription-product-mandate.js' | asset_url | script_tag }}

<!-- Debug Info -->
<script>
console.log('🔥 Mandate Template loaded!');
console.log('🔥 Razorpay Key from settings: {{ settings.razorpay_key_id | default: "rzp_live_SSfTeiwakEqpU0" }}');
console.log('🔥 API URL from settings: {{ settings.subscription_api_url | default: "https://shopify-razorpay-backend-production.up.railway.app" }}');
</script>

<div class="container mx-auto px-4 py-8">
  <!-- Product Header -->
  <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
    <div class="flex flex-col md:flex-row gap-6">
      <div class="md:w-1/2">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.featured_image.alt }}" class="w-full rounded-lg">
        {%- endif -%}
      </div>
      <div class="md:w-1/2">
        <h1 class="text-3xl font-bold mb-4">{{ product.title }}</h1>
        <p class="text-gray-600 mb-6">{{ product.description }}</p>
        
        <!-- Subscription Options -->
        {%- if product.tags contains 'subscription' -%}
          <div class="mb-6">
            <h3 class="text-lg font-semibold mb-3">Choose Subscription Plan</h3>
            <div class="space-y-3" id="subscriptionOptions">
              <!-- 3 Months Plan -->
              <div class="subscription-option border rounded-lg p-4 cursor-pointer hover:border-blue-500 transition-colors" 
                   data-plan="3months" 
                   data-variant-id="46513506189501" 
                   data-plan-id="{{ product.metafields.subscription.plan_3_months_id }}" 
                   data-price="{{ product.metafields.subscription.plan_3_months_price }}">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-semibold text-lg">Monthly for 3 Months</h3>
                  <span class="text-2xl font-bold text-blue-600">₹{{ product.metafields.subscription.plan_3_months_price | divided_by: 100 }}/month</span>
                </div>
                <p class="text-gray-600 text-sm mb-2">{{ product.metafields.subscription.plan_3_months_description }}</p>
                <div class="flex items-center text-green-600 text-sm">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l2-2z" clip-rule="evenodd"></path>
                  </svg>
                  Save {{ product.metafields.subscription.plan_3_months_discount }}% compared to one-time
                </div>
              </div>

              <!-- 6 Months Plan -->
              <div class="subscription-option border rounded-lg p-4 cursor-pointer hover:border-blue-500 transition-colors" 
                   data-plan="6months" 
                   data-variant-id="46513506222269" 
                   data-plan-id="{{ product.metafields.subscription.plan_6_months_id }}" 
                   data-price="{{ product.metafields.subscription.plan_6_months_price }}">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-semibold text-lg">Monthly for 6 Months</h3>
                  <span class="text-2xl font-bold text-blue-600">₹{{ product.metafields.subscription.plan_6_months_price | divided_by: 100 }}/month</span>
                </div>
                <p class="text-gray-600 text-sm mb-2">{{ product.metafields.subscription.plan_6_months_description }}</p>
                <div class="flex items-center text-green-600 text-sm">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l2-2z" clip-rule="evenodd"></path>
                  </svg>
                  Save {{ product.metafields.subscription.plan_6_months_discount }}% compared to one-time
                </div>
              </div>

              <!-- 12 Months Plan -->
              <div class="subscription-option border rounded-lg p-4 cursor-pointer hover:border-blue-500 transition-colors" 
                   data-plan="12months" 
                   data-variant-id="46513506255037" 
                   data-plan-id="{{ product.metafields.subscription.plan_12_months_id }}" 
                   data-price="{{ product.metafields.subscription.plan_12_months_price }}">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-semibold text-lg">Monthly for 12 Months</h3>
                  <span class="text-2xl font-bold text-blue-600">₹{{ product.metafields.subscription.plan_12_months_price | divided_by: 100 }}/month</span>
                </div>
                <p class="text-gray-600 text-sm mb-2">{{ product.metafields.subscription.plan_12_months_description }}</p>
                <div class="flex items-center text-green-600 text-sm">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l2-2z" clip-rule="evenodd"></path>
                  </svg>
                  Save {{ product.metafields.subscription.plan_12_months_discount }}% compared to one-time
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
        
        <!-- Customer Information -->
        <div class="mb-6">
          <h3 class="text-lg font-semibold mb-3">Customer Information</h3>
          <div class="space-y-3">
            {%- if customer -%}
              <input type="email" id="customerEmail" value="{{ customer.email }}" placeholder="Email Address" class="w-full border rounded-lg px-4 py-2" readonly>
              <input type="tel" id="customerPhone" value="{{ customer.phone }}" placeholder="Phone Number" class="w-full border rounded-lg px-4 py-2" {%- if customer.phone -%}readonly{%- endif -%}>
            {%- else -%}
              <input type="email" id="customerEmail" placeholder="Email Address" class="w-full border rounded-lg px-4 py-2" required>
              <input type="tel" id="customerPhone" placeholder="Phone Number" class="w-full border rounded-lg px-4 py-2" required>
            {%- endif -%}
          </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="flex gap-3">
          <button id="subscribeNowBtn" class="flex-1 bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors disabled:bg-gray-400" disabled>
            Subscribe with Auto-pay (Mandate)
          </button>
        </div>
        
        <!-- Info Note -->
        <div class="mt-4 p-4 bg-blue-50 rounded-lg">
          <p class="text-sm text-blue-800">
            <strong>💡 How Auto-pay works:</strong><br>
            1. Click "Subscribe with Auto-pay" to set up automatic payments<br>
            2. Complete the one-time authorization with Razorpay<br>
            3. Future payments will be automatically deducted<br>
            4. You can pause/resume/cancel anytime
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Hidden configuration -->
<script>
  window.subscriptionConfig = {
    apiBase: '{{ settings.subscription_api_url | default: "https://shopify-razorpay-backend-production.up.railway.app" }}',
    razorpay_key_id: '{{ settings.razorpay_key_id | default: "rzp_live_SSfTeiwakEqpU0" }}',
    customerId: {%- if customer -%}'{{ customer.id }}'{%- else -%}null{%- endif -%},
    customerEmail: {%- if customer -%}'{{ customer.email }}'{%- else -%}null{%- endif -%},
    customerPhone: {%- if customer -%}'{{ customer.phone }}'{%- else -%}null{%- endif -%}
  };
</script>

{% schema %}
{
  "name": "Subscription Product Mandate",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show social sharing buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show SKU",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_button",
      "label": "Show dynamic checkout button",
      "info": "Lets customers check out directly using a familiar payment method. [Learn more](https://help.shopify.com/manual/using-themes/change-the-layout/dynamic-checkout)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_pickup_availability",
      "label": "Show pickup availability",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_rating",
      "label": "Show product rating",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_sticky_product_form",
      "label": "Show sticky product form",
      "default": true
    }
  ]
}
{% endschema %}
