{{ 'subscription-management.css' | asset_url | stylesheet_tag }}
{{ 'subscription-management.js' | asset_url | script_tag }}

{%- unless customer -%}
  <div class="container mx-auto px-4 py-8">
    <div class="bg-white rounded-lg shadow-lg p-6 text-center">
      <h2 class="text-2xl font-bold mb-4">Please Log In</h2>
      <p class="text-gray-600 mb-6">You need to be logged in to manage your subscriptions.</p>
      <a href="/account/login" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors">
        Log In
      </a>
    </div>
  </div>
{%- else -%}
  <div class="container mx-auto px-4 py-8">
    {%- if section.settings.show_page_title -%}
      <h1 class="text-3xl font-bold mb-8">{{ section.settings.page_title }}</h1>
    {%- endif -%}
    
    <!-- Customer Lookup Section -->
    {%- if section.settings.show_customer_info -%}
    <div id="customerInfo" class="bg-white rounded-lg shadow-md p-4 mb-6">
      <h3 class="text-lg font-bold mb-4">Current Customer</h3>
      <p><strong>Email:</strong> {{ customer.email }}</p>
      <p><strong>Phone:</strong> {{ customer.phone }}</p>
    </div>
    {%- endif -%}
    
    <!-- Loading State -->
    <div id="loadingState" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
      <p class="mt-4 text-gray-600">Loading your subscriptions...</p>
    </div>
    
    <!-- Subscription Tabs -->
    <div id="subscriptionTabs" class="bg-white rounded-lg shadow-md p-4 mb-6 hidden">
      <div class="flex flex-wrap justify-between items-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4 sm:mb-0">Your Subscriptions</h2>
        <div class="status-tabs">
          <button class="status-tab active" data-filter="active">Active (<span id="activeCount">0</span>)</button>
          <button class="status-tab" data-filter="paused">Paused (<span id="pausedCount">0</span>)</button>
          <button class="status-tab" data-filter="cancelled">Cancelled (<span id="cancelledCount">0</span>)</button>
          <button class="status-tab" data-filter="completed">Completed (<span id="completedCount">0</span>)</button>
        </div>
      </div>
    </div>
    
    <!-- Subscriptions List -->
    <div id="subscriptionsList" class="space-y-6 hidden">
      <!-- Subscriptions will be dynamically added here -->
    </div>
    
    <!-- Product Details Template -->
    <div id="productDetailsTemplate" class="hidden">
      <div class="product-details-section">
        <div class="section-title">Product Details</div>
        <div class="product-grid">
          <!-- Products will be dynamically added here -->
        </div>
      </div>
    </div>
    
    <!-- Empty States -->
    <div id="emptyState" class="text-center py-12 hidden">
      <div class="text-gray-400 mb-4">
        <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
        </svg>
      </div>
      <h3 id="emptyStateTitle" class="text-xl font-semibold text-gray-600 mb-2">No Active Subscriptions</h3>
      <p id="emptyStateMessage" class="text-gray-500 mb-6">You don't have any active subscriptions yet.</p>
      <a href="/collections/all" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors inline-block">
        Browse Products
      </a>
    </div>
  </div>

  <!-- Subscription Action Modal -->
  <div id="actionModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center" style="display: none;">
    <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4 relative z-10">
      <h3 id="modalTitle" class="text-xl font-bold mb-4">Confirm Action</h3>
      <p id="modalMessage" class="text-gray-600 mb-6">Are you sure you want to perform this action?</p>
      <div class="flex gap-3">
        <button id="confirmAction" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-semibold hover:bg-blue-700 transition-colors cursor-pointer">
          Confirm
        </button>
        <button id="cancelAction" class="flex-1 bg-gray-300 text-gray-700 py-2 rounded-lg font-semibold hover:bg-gray-400 transition-colors cursor-pointer">
          Cancel
        </button>
      </div>
    </div>
  </div>

  <!-- Hidden configuration -->
  <script>
    window.subscriptionConfig = {
      apiBase: '{{ settings.subscription_api_url | default: "https://shopify-razorpay-backend-production.up.railway.app" }}',
      customerId: '{{ customer.id }}',
      customerEmail: '{{ customer.email }}',
      customerPhone: '{{ customer.phone }}'
    };
    
    // Debug: Log configuration
    console.log('Subscription Management Config:', window.subscriptionConfig);
    console.log('Liquid template loaded successfully');
    
    // Initialize subscription management when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        console.log('DOM fully loaded - initializing subscription management');
        // The JavaScript will auto-initialize via DOMContentLoaded listener
      });
    } else {
      console.log('DOM already loaded - initializing subscription management immediately');
      // Initialize immediately if DOM is already loaded
      if (typeof SubscriptionManagement !== 'undefined' && !window.subscriptionManagement) {
        window.subscriptionManagement = new SubscriptionManagement();
      }
    }
  </script>
{%- endunless -%}

{% schema %}
{
  "name": "Subscription Management",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_page_title",
      "label": "Show page title",
      "default": true
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page title",
      "default": "Subscription Management"
    },
    {
      "type": "checkbox",
      "id": "show_customer_info",
      "label": "Show customer information",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_subscription_actions",
      "label": "Enable subscription actions (pause/resume/cancel)",
      "default": true
    }
  ]
}
{% endschema %}